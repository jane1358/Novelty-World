# Supabase project credentials (safe to be public — Row Level Security protects data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only Supabase credentials (used by CLI / migration scripts — keep secret)
SUPABASE_PROJECT_REF=your-project-id
SUPABASE_DB_PASSWORD=your-db-password

# Service-role key — server-only, bypasses RLS. Used by the authoritative
# game routes (e.g. /api/monopoly) to write game state while clients stay
# read-only. NEVER expose to the browser (no NEXT_PUBLIC_ prefix).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
