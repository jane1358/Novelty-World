# Supabase project credentials (safe to be public — Row Level Security protects data)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ElevenLabs API key for Finland Catalogue text-to-speech (server-only, never exposed to client).
# Create at https://elevenlabs.io → Profile → API Keys. Only the "text_to_speech" permission is needed.
ELEVENLABS_API_KEY=your-elevenlabs-key
