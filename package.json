{
  "name": "novelty-world",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --port 3001",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:slow": "vitest run --config vitest.slow.config.ts",
    "sim": "tsx src/projects/monopoly/bots/simulate-cli.ts",
    "sim:versus": "tsx src/projects/monopoly/bots/versus-cli.ts",
    "sim:gauntlet": "tsx src/projects/monopoly/bots/gauntlet-cli.ts",
    "sim:verify": "tsx src/projects/monopoly/bots/verify-cli.ts",
    "sim:ratings": "tsx src/projects/monopoly/bots/ratings-cli.ts",
    "sim:optimize": "tsx src/projects/monopoly/bots/optimize-cli.ts",
    "game:review": "tsx src/projects/monopoly/bots/review-cli.ts",
    "bot-brief": "node src/projects/monopoly/bots/bot-brief-cli.mjs",
    "bench": "vitest bench --run",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "clsx": "^2.1.1",
    "d3-dag": "^1.2.1",
    "lucide-react": "^1.7.0",
    "msedge-tts": "^2.0.5",
    "next": "^16.2.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "eslint": "^9",
    "eslint-config-next": "^16.2.2",
    "eslint-plugin-security": "^4.0.0",
    "highs": "^1.8.0",
    "postcss": "^8",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.2",
    "ws": "^8.20.0"
  }
}
